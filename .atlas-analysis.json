  "keyFeatures": [
    "Transparent git decorator with zero workflow changes",
    "AI session discovery across 10+ coding tools",
    "Automatic anchor creation linking commits to AI context",
    "Code attribution tracking (AI vs human lines)",
    "Local SQLite + orphan branch storage",
    "Interactive TUI for sessions and analytics",
    "JSON output mode for AI agents (--agent flag)",
    "Secret redaction for safe sharing",
    "Token counting and cost tracking",
    "Agent lifecycle hooks for real-time session linking"
  ],
  "publicApiSurface": [
    "oobo setup",
    "oobo commit",
    "oobo push",
    "oobo sessions [list|show|search|export]",
